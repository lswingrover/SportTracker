EVENT_ID=PTAwMDAwNDI2MDU90
DIVISION_ID=203854
TEAM_ID=201772
TEAM_NAME=208 U14 Red

# ── NIWP WordPress API (primary live source) ─────────────────────────────────
# Set NIWP_API_ENABLED=true to use the live northidahowaterpolo.org REST API.
# This is the highest-priority data source — no auth or API key needed.
# NIWP_TEAM_PREFIX filters by squad: B (Boys Varsity, default), G (Girls Varsity),
# BJV (Boys JV), GJV (Girls JV).
NIWP_API_ENABLED=true
NIWP_TEAM_PREFIX=B

# ── 6-8 Sports (USAWP Junior Olympics live scores) ───────────────────────────
# NarWatch auto-detects JOs — no manual toggle required.
# When any Narwhal game is live or scheduled today on 6-8 Sports, this source
# activates automatically (overrides NIWP for the day) and reverts afterward.
#
# SIXEIGHT_ENABLED=true  → always use 6-8 Sports (bypass auto-detect; for testing)
# SIXEIGHT_DISABLED=true → never use 6-8 Sports (suppress auto-detect entirely)
# SIXEIGHT_LEAGUE_ID     → optional: pin a specific JO league UUID; blank = auto-discover
# SIXEIGHT_TEAM_NAME     → team name fragment for filtering (default: "Narwhal")
SIXEIGHT_ENABLED=
SIXEIGHT_DISABLED=
SIXEIGHT_LEAGUE_ID=
SIXEIGHT_TEAM_NAME=Narwhal

# ── TorMatch (tournament live scores) ────────────────────────────────────────
# Set TORMATCH_TOURNAMENT_ID to the tournament's numeric ID on tormatch.com.
# API key is already baked into tormatch.js (public key, no env var needed).
TORMATCH_TOURNAMENT_ID=

# ── SportsEngine TourneyMachine (HTML scraper) ───────────────────────────────
# Set SPORTSENGINE_TOURNAMENT_ID to the tourneymachine.com hash ID.
# Discover it: Google `site:tourneymachine.com "Tournament Name"` — the ID
# is the IDTournament= query param in the URL.
# SPORTSENGINE_TEAM_NAME: team fragment (default: "Narwhal").
SPORTSENGINE_TOURNAMENT_ID=
SPORTSENGINE_TEAM_NAME=Narwhal

# ── Google Sheets live data integration ──────────────────────────────────────
# When both vars are set, /api/tournament delegates to /api/sheets.js.
# The sheet must be set to "Anyone with the link can view".
#
# Setup steps:
#   1. Make a copy of the NarWatch template sheet (see docs/SHEETS_SETUP.md).
#   2. Share it as "Anyone with the link can view".
#   3. Copy the Sheet ID from the URL:
#      https://docs.google.com/spreadsheets/d/SHEET_ID_IS_HERE/edit
#   4. Create a Google Cloud API key restricted to the Sheets API v4.
#      (console.cloud.google.com → APIs & Services → Credentials)
#   5. Paste both values below and redeploy.
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_API_KEY=

# ── Web Push ──────────────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── Vercel Blob (auto-injected when blob store is linked to the project) ──────
BLOB_READ_WRITE_TOKEN=
